{
  "name": "@tsed/apollo",
  "description": "Apollo package for Ts.ED framework",
  "type": "module",
  "version": "8.17.0",
  "source": "./src/index.ts",
  "main": "./lib/esm/index.js",
  "module": "./lib/esm/index.js",
  "typings": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "tsed-source": "./src/index.ts",
      "types": "./lib/types/index.d.ts",
      "import": "./lib/esm/index.js",
      "default": "./lib/esm/index.js"
    }
  },
  "scripts": {
    "build": "yarn barrels && yarn build:ts",
    "barrels": "barrels",
    "test": "vitest run",
    "build:ts": "tsc --build tsconfig.esm.json",
    "test:ci": "vitest run --coverage.thresholds.autoUpdate=true"
  },
  "dependencies": {
    "tslib": ">=2.7.0"
  },
  "devDependencies": {
    "@apollo/datasource-rest": "6.4.1",
    "@apollo/server": "^5.2.0",
    "@as-integrations/express4": "1.1.2",
    "@as-integrations/express5": "1.1.2",
    "@as-integrations/fastify": "3.1.0",
    "@as-integrations/koa": "1.1.1",
    "@tsed/barrels": "workspace:*",
    "@tsed/core": "workspace:*",
    "@tsed/di": "workspace:*",
    "@tsed/logger": "^8.0.0",
    "@tsed/platform-http": "workspace:*",
    "@tsed/typescript": "workspace:*",
    "apollo-datasource-http": "0.21.0",
    "apollo-server-testing": "2.26.2",
    "eslint": "9.12.0",
    "graphql": "16.12.0",
    "typescript": "6.0.2",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "@apollo/server": ">=4.12.0",
    "@as-integrations/express4": ">=1.1.2",
    "@as-integrations/express5": ">=1.1.2",
    "@as-integrations/fastify": ">=3.1.0",
    "@as-integrations/koa": ">=1.1.1",
    "@tsed/core": ">=8.0.0",
    "@tsed/di": ">=8.0.0",
    "@tsed/logger": ">=8.0.0",
    "@tsed/platform-http": ">=8.0.0",
    "graphql": ">16.0.0"
  },
  "peerDependenciesMeta": {
    "@as-integrations/express4": {
      "optional": true
    },
    "@as-integrations/express5": {
      "optional": true
    },
    "@as-integrations/fastify": {
      "optional": true
    },
    "@as-integrations/koa": {
      "optional": true
    }
  }
}
